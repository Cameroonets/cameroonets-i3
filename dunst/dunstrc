[global]
    origin = bottom-right
    offset = 20x60
    layer = overlay
    default_timeout = 5000
    width = 300
    height = 110
    corner_radius = 8
    frame_width = 2
    font = Sans 10

[urgency_low]
    background = "#282827"
    foreground = "#EBECEA"
    frame_color = "#3A462E"

[urgency_normal]
    background = "#282827"
    foreground = "#EBECEA"
    frame_color = "#23281A"

[urgency_high]
    background = "#282827"
    foreground = "#EBECEA"
    frame_color = "#A0B77D"

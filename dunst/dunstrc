[global]
    origin = bottom-right
    offset = 20x60
    layer = overlay
    default_timeout = 5000
    width = 300
    height = 110
    corner_radius = 8
    frame_width = 2
    font = Sans 10

[urgency_low]
    background = "#252224"
    foreground = "#FAF6F1"
    frame_color = "#B57439"

[urgency_normal]
    background = "#252224"
    foreground = "#FAF6F1"
    frame_color = "#8A2A33"

[urgency_high]
    background = "#252224"
    foreground = "#FAF6F1"
    frame_color = "#B57439"
